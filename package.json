{
  "name": "@kastalien-research/thoughtbox",
  "version": "1.2.2",
  "description": "Code-mode-first MCP gateway for discovering and calling upstream MCP tools through a two-tool surface",
  "mcpName": "io.github.Kastalien-Research/thoughtbox",
  "license": "MIT",
  "author": "glassBead at Kastalien Research",
  "homepage": "https://github.com/Kastalien-Research/thoughtbox",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kastalien-Research/thoughtbox.git"
  },
  "bugs": "https://github.com/Kastalien-Research/thoughtbox/issues",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "thoughtbox",
    "gateway",
    "proxy",
    "code-mode",
    "ai",
    "llm"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "src/index.ts",
  "types": "./dist/index.d.ts",
  "bin": {
    "thoughtbox": "./dist/index.js",
    "thoughtbox-hub-channel": "./dist/channel/hub-channel.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "embed-templates": "tsx scripts/embed-templates.ts",
    "embed-loops": "tsx scripts/embed-loops.ts",
    "embed": "bun run embed-templates && bun run embed-loops",
    "dev": "bun run embed && tsx src/index.ts",
    "demo:gateway-fixture": "tsx scripts/demo/gateway-fixture.ts",
    "build": "bun build src/marketplace.ts --outfile index.js --target node",
    "build:local": "bun run embed && tsc && shx cp -r src/resources dist/ && shx cp -r templates dist/ && shx chmod +x dist/*.js",
    "start": "node index.js",
    "start:stateful": "node dist/http-stateful.js",
    "prepublishOnly": "bun run build:local",
    "watch": "tsc --watch",
    "check:cycles": "./scripts/check-cycles.sh",
    "check:cycles:strict": "./scripts/check-cycles.sh --strict",
    "changelog:update": "git log --format='%H|%s|%an|%ad' HEAD~20..HEAD > .changelog-commits.txt && tsx scripts/changelog-update.ts .changelog-commits.txt && rm .changelog-commits.txt",
    "prepare": "husky",
    "test": "bun run build:local && vitest run",
    "test:agentic": "bun run build:local && tsx scripts/agentic-test.ts --all",
    "test:agentic:tool": "bun run build:local && tsx scripts/agentic-test.ts --tool",
    "test:agentic:quick": "tsx scripts/agentic-test.ts --tool",
    "benchmark": "tsx dgm-specs/harness/cli.ts run",
    "benchmark:baseline": "tsx dgm-specs/harness/cli.ts baseline",
    "benchmark:report": "tsx dgm-specs/harness/cli.ts report",
    "improvement-loop": "tsx scripts/agents/run-improvement-loop.ts",
    "improvement-loop:dry": "tsx scripts/agents/run-improvement-loop.ts --dry-run --verbose",
    "improvement-loop:verbose": "tsx scripts/agents/run-improvement-loop.ts --verbose",
    "test:agentops": "vitest run agentops/tests/",
    "test:behavioral": "tsx scripts/agents/test-behavioral-contracts.ts",
    "test:behavioral:variance": "tsx scripts/agents/test-behavioral-contracts.ts --variance-only",
    "agentops:daily": "tsx agentops/runner/cli.ts daily-dev-brief",
    "agentops:implement": "tsx agentops/runner/cli.ts implement",
    "check:lint": "oxlint -c oxlint.json src/",
    "check:types": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.25.3",
    "@supabase/supabase-js": "^2.99.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.6.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "fast-xml-parser": "^4.5.3",
    "gray-matter": "^4.0.3",
    "jose": "6.2.1",
    "jsonwebtoken": "^9.0.3",
    "langsmith": "^0.5.2",
    "openai": "^4.104.0",
    "rss-parser": "^3.13.0",
    "ws": "^8.18.3",
    "yaml": "^2.8.2",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.24.5"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.76",
    "@anthropic-ai/sdk": "^0.39.0",
    "@octokit/rest": "^20.1.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.18.12",
    "@types/ws": "^8.18.1",
    "@types/yargs": "^17.0.32",
    "dotenv": "^17.2.3",
    "husky": "^9.1.6",
    "madge": "^8.0.0",
    "oxlint": "^1.56.0",
    "shx": "^0.3.4",
    "tsx": "^4.20.6",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  }
}
