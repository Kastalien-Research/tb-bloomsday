{
    "compilerOptions": {
      "target": "ES2022",
      "module": "ES2022",
      "moduleResolution": "node",
      "outDir": "./dist",
      "rootDir": "./src",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true
    },
    "include": [
      "src/marketplace.ts",
      "src/gateway/**/*.ts",
      "src/code-mode/**/*.ts",
      "src/dedalus-marketplace/**/*.ts",
      "src/types.ts"
    ],
    "exclude": [
      "src/**/__tests__/**",
      "src/**/*.test.ts",
      "src/observatory/**"
    ]
  }
